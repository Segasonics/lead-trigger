# ─── Trigger.dev ────────────────────────────────────────────────────────────
# Get these from https://trigger.dev → your project → Settings
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx
TRIGGER_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxx

# ─── Serper.dev — Google Search API ─────────────────────────────────────────
# Sign up at https://serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=your_serper_api_key

# ─── Google Sheets — Lead Output ────────────────────────────────────────────
# 1. Create a Google Sheet
# 2. Copy the spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# 3. Create a service account at console.cloud.google.com → IAM → Service Accounts
# 4. Enable Google Sheets API in your project
# 5. Download the service account JSON key
# 6. Share your Google Sheet with the service account email (Editor access)
GOOGLE_SHEET_ID=your_google_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Search Configuration ────────────────────────────────────────────────────
# Semicolon-separated list of cities/regions to search each week
# Add as many as you want — each location runs 4 search queries
SEARCH_LOCATIONS=Austin, Texas;Dallas, Texas;Houston, Texas;Phoenix, Arizona;Denver, Colorado
CLICKUP_API_KEY=pk_your_clickup_api_key